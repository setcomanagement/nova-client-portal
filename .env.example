# NOVA Portal — environment variables
# Copy to .env.local for local dev. Set the same keys in the Vercel project for prod.

# --- Database ---
# Leave UNSET locally to use the zero-infra in-process PGlite (./.pglite).
# Set to a Postgres connection string (e.g. Neon) for production.
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# --- Auth (REQUIRED) ---
# Secret used to sign session JWTs (HS256). Generate a strong random value:
#   openssl rand -base64 48
# The app throws on startup if this is missing.
JWT_SECRET="change-me-to-a-long-random-string"

# --- Seeding / provisioning ---
# Password for the seeded super_admin (matthewbryanchuang@gmail.com) in prod.
# Local dev falls back to a weak default if unset.
# ADMIN_PASSWORD="a-strong-admin-password"
# Demo orgs (Tone/Akira/Alex) only seed against a real DB when this is "true".
# Production should leave it unset and provision real clients via the admin UI.
# SEED_DEMO="false"

# --- Calendly OAuth (Connect Calendly → sync bookings/leads) ---
# Create an OAuth app at https://developer.calendly.com (My Apps → Create) with
# redirect URI https://www.setco.pro/api/calendly/callback (and
# http://localhost:3000/api/calendly/callback for local). Without these, the
# Integrations page shows "Setup pending".
# CALENDLY_CLIENT_ID="..."
# CALENDLY_CLIENT_SECRET="..."

# --- Recap ingestion (POST /api/recaps from nova-recap-publish) ---
# Bearer token the skill must send. In local dev, if unset, the route accepts
# the fallback token "dev-recap-token". In production this MUST be set or the
# endpoint refuses all requests.
# RECAP_INGEST_TOKEN="a-long-random-token"

# --- Client provisioning API (POST /api/clients from Make.com / external) ---
# Shared secret callers must send as `Authorization: Bearer <PROVISION_API_KEY>`
# to create a client org + invite its owner over HTTP. Compared in constant time.
# If unset, the endpoint refuses all requests (returns 500). Generate with:
#   openssl rand -base64 48
# PROVISION_API_KEY="a-long-random-token"

# --- MCP connector (claude.ai "Onboard a NOVA client" tool) ---
# The MCP server lives at /mcp and is gated by OAuth 2.1 via an external IdP
# (Stytch / WorkOS / etc.) that supports Dynamic Client Registration. nova-portal
# acts only as the OAuth resource server: it validates the IdP's access token.
# If these are unset, the MCP endpoint rejects every request (401).
#   MCP_OAUTH_ISSUER   = the IdP issuer URL (token `iss`), e.g. https://xxx.stytch.com
#   MCP_RESOURCE_URL   = canonical URL of this MCP server (token audience), no trailing slash
#   MCP_OAUTH_JWKS_URL = optional; defaults to ${MCP_OAUTH_ISSUER}/.well-known/jwks.json
#   MCP_DEFAULT_DISCORD_INVITE = optional; NOVA community invite used when the tool omits one
# MCP_OAUTH_ISSUER="https://your-project.stytch.com"
# MCP_RESOURCE_URL="https://www.setco.pro/mcp"
# MCP_OAUTH_JWKS_URL=""
# MCP_DEFAULT_DISCORD_INVITE="https://discord.gg/Ahb3zhNcSX"
